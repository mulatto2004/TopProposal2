# ─────────────────────────────────────────────────────────────────────────────
# TopProposal — Environment Variables
# Copy this file to .env.local for local development
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE (Supabase) ───────────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → Database → Connection String
# Use "Transaction" mode URL for DATABASE_URL (pooled, port 6543)
# Use "Session" mode URL for DIRECT_URL (direct, port 5432)
DATABASE_URL=""
DIRECT_URL=""

# ── NEXTAUTH v5 ───────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32  (or: npx auth secret)
AUTH_SECRET=""
# Your app URL (use http://localhost:3000 for development)
AUTH_URL=""

# Google OAuth — get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create "OAuth 2.0 Client ID" for a Web Application
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── STRIPE ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook secret — get from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=""
# Price IDs — create in Stripe Dashboard → Products
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""

# ── RESEND (Email) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=""
# The "from" email address (must be a verified domain in Resend)
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME=""

# ── APP CONFIG ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=""
NEXT_PUBLIC_APP_NAME=""

# ── FILE UPLOADS (Optional — for logo uploads) ───────────────────────────────
# Supabase Storage bucket or Uploadthing
# Get from: https://uploadthing.com → Dashboard → API Keys
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""